# Vector MCP Go Configuration

# API and Socket Settings
API_PORT=47821
DATA_DIR=./data

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
# LLM Provider: 'gemini' or 'ollama'
LLM_PROVIDER=gemini
# If using ollama, set your local model name
OLLAMA_MODEL=llama3

# Indexing Configuration
PROJECT_ROOT=.
MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDER_POOL_SIZE=1

# Watcher
DISABLE_FILE_WATCHER=false
ENABLE_LIVE_INDEXING=true
