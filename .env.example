# Project Root to index (default: current directory)
PROJECT_ROOT=.

# Data directory for database and models (default: ~/.local/share/vector-mcp-go)
# DATA_DIR=/path/to/your/data/dir (Default: ~/.local/share/vector-mcp-go)

# Explicit paths (overrides DATA_DIR based paths)
# DB_PATH=/path/to/your/db (Default: DATA_DIR/lancedb)
# MODELS_DIR=/path/to/your/models (Default: DATA_DIR/models)
# LOG_PATH=/path/to/your/log (Default: DATA_DIR/server.log)

# Path to libonnxruntime.so (optional)
# ONNX_LIB_PATH=./lib/libonnxruntime.so

# Model to use (default: Xenova/bge-m3)
# MODEL_NAME=Xenova/bge-m3

# Hugging Face Token (optional, for private models)
# HF_TOKEN=your_token_here
